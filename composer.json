{
    "name": "phlex/media-server",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "workerman/workerman": "^5.0",
        "workerman/webman-framework": "^2.0",
        "workerman/mysql": "^1.0",
        "workerman/redis": "^2.0",
        "symfony/yaml": "^7.0",
        "monolog/monolog": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Phlex\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phlex\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
